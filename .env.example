# Project Harimau V2 Configuration

# Google Cloud
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=credentials.json

# Google Threat Intelligence
GTI_API_KEY=your-virustotal-api-key

# Google Web Risk
WEBRISK_API_KEY=your-webrisk-api-key

# Logging
LOG_LEVEL=INFO
# DEBUG for full trace

# App
POLL_INTERVAL=10
MAX_DEPTH=2

# Detection Agent Integration (Phase 6 - A2A)
# BACKEND ONLY — these vars are set on the harimau-backend Cloud Run service, NOT the frontend.
# Toggle without redeploying: gcloud run services update harimau-backend --set-env-vars DETECTION_AGENT_ENABLED=true,DETECTION_AGENT_URL=https://...
# When enabled, backend forwards completed investigation reports to the detection agent via A2A after each investigation.
DETECTION_AGENT_ENABLED=false
DETECTION_AGENT_URL=
